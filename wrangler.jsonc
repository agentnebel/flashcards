{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "flashcards",
  "main": "worker/index.ts",
  "compatibility_date": "2025-01-09",
  "compatibility_flags": ["nodejs_compat"],
  "observability": { "enabled": true },

  // Static Assets: das gebaute React-Bundle. /api/* läuft zuerst im Worker.
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"],
    "not_found_handling": "single-page-application"
  },

  // D1: anlegen mit `wrangler d1 create flashcards-db`, dann database_id hier eintragen.
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "flashcards-db",
      "database_id": "REPLACE_WITH_D1_DATABASE_ID"
    }
  ],

  // R2 für Medien: `wrangler r2 bucket create flashcards-media`.
  "r2_buckets": [
    {
      "binding": "MEDIA",
      "bucket_name": "flashcards-media"
    }
  ]

  // Secret: `wrangler secret put JWT_SECRET`
}
