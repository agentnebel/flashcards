{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "flashcards",
  "main": "worker/index.ts",
  "compatibility_date": "2025-01-09",
  "compatibility_flags": ["nodejs_compat"],
  "observability": { "enabled": true },

  // Static Assets: das gebaute React-Bundle. /api/* läuft zuerst im Worker.
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"],
    "not_found_handling": "single-page-application"
  },

  // D1: angelegt mit `wrangler d1 create flashcards-db`.
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "flashcards-db",
      "database_id": "45ddbb44-7cbe-4b31-98a8-4f1ffaa019af"
    }
  ]

  // R2 für Medien: aktiviert 28.06.2026
  ,"r2_buckets": [
    { "binding": "MEDIA", "bucket_name": "flashcards-media" }
  ]

  // Rate-Limiting für /api/auth/* (Bruteforce-/Massenregistrierungs-Schutz):
  // 10 Versuche pro IP und 60 s. "unsafe" ist Cloudflares Namensraum für das
  // Rate-Limiting-Binding (offene Beta), nicht etwas Unsicheres.
  ,"unsafe": {
    "bindings": [
      {
        "name": "AUTH_LIMITER",
        "type": "ratelimit",
        "namespace_id": "1001",
        "simple": { "limit": 10, "period": 60 }
      }
    ]
  }

  // Secret: `wrangler secret put JWT_SECRET`
}
