{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "flashcards",
  "main": "worker/index.ts",
  "compatibility_date": "2025-01-09",
  "compatibility_flags": ["nodejs_compat"],
  "observability": { "enabled": true },

  // Static Assets: das gebaute React-Bundle. /api/* läuft zuerst im Worker.
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"],
    "not_found_handling": "single-page-application"
  },

  // D1: angelegt mit `wrangler d1 create flashcards-db`.
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "flashcards-db",
      "database_id": "45ddbb44-7cbe-4b31-98a8-4f1ffaa019af"
    }
  ]

  // R2 für Medien (M3): erst im Cloudflare-Dashboard R2 aktivieren, dann
  // `wrangler r2 bucket create flashcards-media` und folgenden Block einkommentieren:
  // "r2_buckets": [
  //   { "binding": "MEDIA", "bucket_name": "flashcards-media" }
  // ]

  // Secret: `wrangler secret put JWT_SECRET`
}
